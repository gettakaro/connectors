# === Takaro Connection (shared across all connectors) ===
TAKARO_WS_URL=wss://connect.takaro.io/
TAKARO_REGISTRATION_TOKEN=
TAKARO_DEBUG=false
# Per-connector identity token — each docker-compose service sets its own default
# (e.g. takaro-rust-dev, takaro-paper-dev). Override here to set all at once.
TAKARO_IDENTITY_TOKEN=

# === Rust Connector ===
RCON_PASSWORD=takaro123
RUST_SERVER_NAME=Takaro Dev
RUST_SERVER_SEED=12345
RUST_SERVER_WORLDSIZE=1000
RUST_SERVER_MAXPLAYERS=10

# === Minecraft Connector ===
# Uses RCON_PASSWORD from above (shared between Rust and Minecraft connectors)
